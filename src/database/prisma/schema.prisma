generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Account {
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime
  User              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerAccountId])
}

model AgentPrompt {
  id                  String                @id @db.Uuid
  userId              String
  agentId             String?
  status              PromptStatus          @default(draft)
  version             Int                   @default(1)
  sections            Json
  promptText          String
  businessName        String?
  businessSector      String?
  createdAt           DateTime              @default(now())
  updatedAt           DateTime
  User                User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  AgentPromptRevision AgentPromptRevision[]

  @@index([agentId])
  @@index([businessName])
  @@index([businessSector])
  @@index([sections], type: Gin)
  @@index([status])
  @@index([userId])
}

model AgentPromptRevision {
  id                 String      @id @db.Uuid
  promptId           String      @db.Uuid
  revisionNumber     Int
  sectionsSnapshot   Json
  promptTextSnapshot String
  publishedBy        String
  publishedAt        DateTime    @default(now())
  notes              String?
  AgentPrompt        AgentPrompt @relation(fields: [promptId], references: [id], onDelete: Cascade)
  User               User        @relation(fields: [publishedBy], references: [id], onDelete: Cascade)

  @@unique([promptId, revisionNumber])
  @@index([publishedAt])
}

model ApiKey {
  id        String   @id
  url       String
  key       String
  createdAt DateTime @default(now())
  updatedAt DateTime
  User      User[]
}

model Appointment {
  id        String            @id
  userId    String
  sessionId Int
  startTime DateTime
  endTime   DateTime
  timezone  String
  status    AppointmentStatus @default(PENDIENTE)
  createdAt DateTime          @default(now())
  updatedAt DateTime
  serviceId String?
  Service   Service?          @relation(fields: [serviceId], references: [id])
  Session   Session           @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  User      User              @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model GuidesUrl {
  id          String   @id
  path        String
  title       String
  description String?
  url         String
  createdAt   DateTime @default(now())
  updatedAt   DateTime
  tipo        String?
}

model Instancias {
  id           Int     @id @default(autoincrement())
  instanceName String
  userId       String
  instanceId   String
  instanceType String? @default("Whatsapp")
  User         User    @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Log {
  id        String   @id
  level     String
  message   String
  context   String?
  timestamp DateTime @default(now())
}

model Manual {
  id          String   @id
  name        String
  description String?
  url         String
  createdAt   DateTime @default(now())
  updatedAt   DateTime
}

model Module {
  id                     String       @id
  label                  String
  route                  String
  icon                   String
  showInSidebar          Boolean?     @default(true)
  hiddenModuleToSelector Boolean?     @default(false)
  adminOnly              Boolean      @default(false)
  requiresPremium        Boolean      @default(false)
  allowedPlans           Plan[]
  order                  Int          @default(0)
  createdAt              DateTime     @default(now())
  updatedAt              DateTime
  showOnlySelectedPlans  Boolean?     @default(false)
  customUrl              String?
  ModuleItem             ModuleItem[]
  User                   User[]       @relation("UserModules")
}

model ModuleItem {
  id        String   @id
  title     String
  url       String
  moduleId  String
  createdAt DateTime @default(now())
  updatedAt DateTime
  Module    Module   @relation(fields: [moduleId], references: [id])
}

model Pausar {
  userId      String
  mensaje     String   @default("Fue un gusto ayudarte.")
  tipo        String   @default("abrir")
  baseurl     String
  createdAt   DateTime @default(now())
  updatedAt   DateTime
  apikeyId    String
  instanciaId String
  id          Int      @id @default(autoincrement())
  User        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Product {
  id          String   @id
  userId      String
  title       String
  description String?
  price       Decimal  @db.Decimal(65, 2)
  sku         String?  @unique
  stock       Int      @default(0)
  isActive    Boolean  @default(true)
  images      String[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime
  category    String
  tags        String[]
  User        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, title])
}

model PromptInstance {
  id           Int     @id @default(autoincrement())
  instanceType String?
  description  String?
  content      String?
  instanceId   Int?
  userId       String
  User         User    @relation(fields: [userId], references: [id])
}

model PromptTemplate {
  id          String   @id
  name        String   @unique
  description String?
  content     String
  category    String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime
}

model Registro {
  tipo      TipoRegistro
  fecha     DateTime?
  estado    String?
  resumen   String?
  lead      Boolean?
  nombre    String?
  detalles  String?
  meta      Json?
  sessionId Int
  createdAt DateTime     @default(now())
  updatedAt DateTime
  id        Int          @id @default(autoincrement())
  Session   Session      @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([tipo, fecha])
}

model Reminders {
  id           String      @id
  title        String
  description  String?
  time         String?
  repeatType   RepeatType? @default(NONE)
  repeatEvery  Int?
  endsAt       DateTime?
  instanceName String?
  serverUrl    String?
  apikey       String?
  userId       String?
  workflowId   String?
  remoteJid    String?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime
  pushName     String?
  isSchedule   Boolean?    @default(false)
}

model Service {
  id          String        @id
  userId      String
  name        String
  description String?
  messageText String
  createdAt   DateTime      @default(now())
  Appointment Appointment[]
  User        User          @relation(fields: [userId], references: [id])
}

model Session {
  userId         String
  remoteJid      String
  pushName       String
  instanceId     String
  createdAt      DateTime        @default(now())
  updatedAt      DateTime
  status         Boolean
  id             Int             @id @default(autoincrement())
  seguimientos   String?         @default("")
  inactividad    String?         @default("")
  sessionDelay   String?
  flujos         String?         @default("")
  remoteJidAlt   String?
  Appointment    Appointment[]
  Registro       Registro[]
  User           User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  SessionTag     SessionTag[]
  SessionTrigger SessionTrigger?

  @@index([userId, remoteJid])
}

model SessionTag {
  sessionId Int
  tagId     Int
  Session   Session @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  Tag       Tag     @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([sessionId, tagId])
}

model SessionTrigger {
  id        Int      @id @default(autoincrement())
  time      String
  createdAt DateTime @default(now())
  updatedAt DateTime
  sessionId Int      @unique
  Session   Session  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
}

model SystemMessage {
  id         String        @id
  message    String
  userId     String
  createdAt  DateTime      @default(now())
  updatedAt  DateTime
  title      String        @default("Sin título")
  typePrompt TypePromptAi? @default(TRAINING)
  User       User          @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Tag {
  id         Int          @id @default(autoincrement())
  userId     String
  name       String
  slug       String
  color      String?
  createdAt  DateTime     @default(now())
  updatedAt  DateTime
  SessionTag SessionTag[]
  User       User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, slug])
}

model Tools {
  id          String   @id
  name        String
  description String?
  userId      String
  createdAt   DateTime @default(now())
  updatedAt   DateTime
  User        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id                                 String                 @id
  name                               String?
  email                              String                 @unique
  password                           String?
  emailVerified                      DateTime?
  image                              String?
  role                               Role                   @default(user)
  createdAt                          DateTime               @default(now())
  updatedAt                          DateTime
  apiUrl                             String                 @default("https://api.openAI.co")
  company                            String                 @default("Empresa Demo")
  lat                                String                 @default("0.0000")
  lng                                String                 @default("0.0000")
  mapsUrl                            String                 @default("https://maps.google.com/?q=0,0")
  notificationNumber                 String                 @default("0000000000")
  openingPhrase                      String?                @default("DEPRECATED")
  apiKeyId                           String?
  del_seguimiento                    String?                @default("Estamos para servirle.")
  plan                               Plan                   @default(basico)
  autoReactivate                     String?
  webhookUrl                         String?                @default("https://n8npro.verzay.co/webhook")
  theme                              ThemeApp?              @default(Default)
  muteAgentResponses                 Boolean                @default(false)
  timezone                           String?
  meetingDuration                    Int?
  onFacebook                         Boolean                @default(false)
  onInstagram                        Boolean                @default(false)
  aiModelId                          String?
  defaultAiModelId                   String?
  defaultProviderId                  String?
  delayTimeGPT                       String?
  meetingUrl                         String?
  Account                            Account[]
  AgentPrompt                        AgentPrompt[]
  AgentPromptRevision                AgentPromptRevision[]
  Appointment                        Appointment[]
  Instancias                         Instancias[]
  Pausar                             Pausar[]
  Product                            Product[]
  PromptInstance                     PromptInstance[]
  Service                            Service[]
  Session                            Session[]
  SystemMessage                      SystemMessage[]
  Tag                                Tag[]
  Tools                              Tools[]
  ApiKey                             ApiKey?                @relation(fields: [apiKeyId], references: [id])
  ai_models                          ai_models?             @relation(fields: [defaultAiModelId], references: [id])
  UserAvailability                   UserAvailability[]
  finance_accounts                   finance_accounts[]
  finance_attachments                finance_attachments[]
  finance_categories                 finance_categories[]
  finance_transactions               finance_transactions[]
  ia_credits                         ia_credits?
  reseller_reseller_reselleridToUser reseller[]             @relation("reseller_reselleridToUser")
  reseller_reseller_userIdToUser     reseller[]             @relation("reseller_userIdToUser")
  user_ai_configs                    user_ai_configs[]
  Module                             Module[]               @relation("UserModules")
}

model UserAvailability {
  id        String @id
  userId    String
  dayOfWeek Int
  startTime String
  endTime   String
  User      User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, dayOfWeek, startTime, endTime])
}

model VerificationToken {
  identifier String   @id @unique
  token      String
  expires    DateTime
}

model Workflow {
  id           String         @id
  userId       String
  name         String
  description  String?
  definition   String
  status       String
  createdAt    DateTime       @default(now())
  updateAt     DateTime
  umbral       Float          @default(0.5)
  WorkflowEdge WorkflowEdge[]

  @@unique([name, userId])
}

model WorkflowEdge {
  id                                               String       @id
  workflowId                                       String
  sourceId                                         String
  targetId                                         String
  createdAt                                        DateTime     @default(now())
  WorkflowNode_WorkflowEdge_sourceIdToWorkflowNode WorkflowNode @relation("WorkflowEdge_sourceIdToWorkflowNode", fields: [sourceId], references: [id], onDelete: Cascade)
  WorkflowNode_WorkflowEdge_targetIdToWorkflowNode WorkflowNode @relation("WorkflowEdge_targetIdToWorkflowNode", fields: [targetId], references: [id], onDelete: Cascade)
  Workflow                                         Workflow     @relation(fields: [workflowId], references: [id], onDelete: Cascade)

  @@unique([workflowId, sourceId])
  @@index([sourceId])
  @@index([targetId])
  @@index([workflowId])
}

model WorkflowNode {
  id                                               String         @id
  workflowId                                       String
  message                                          String
  createdAt                                        DateTime       @default(now())
  updatedAt                                        DateTime
  tipo                                             String
  url                                              String?
  delay                                            String?
  inactividad                                      Boolean?
  name_file                                        String?
  order                                            Int            @default(0)
  posX                                             Float?
  posY                                             Float?
  WorkflowEdge_WorkflowEdge_sourceIdToWorkflowNode WorkflowEdge[] @relation("WorkflowEdge_sourceIdToWorkflowNode")
  WorkflowEdge_WorkflowEdge_targetIdToWorkflowNode WorkflowEdge[] @relation("WorkflowEdge_targetIdToWorkflowNode")
}

model ai_models {
  id           String       @id
  providerId   String
  name         String
  description  String?
  costPerToken Float?
  createdAt    DateTime     @default(now())
  modelName    String?
  updatedAt    DateTime
  User         User[]
  ai_providers ai_providers @relation(fields: [providerId], references: [id])

  @@unique([providerId, name])
}

model ai_providers {
  id              String            @id
  name            String            @unique
  description     String?
  aiModel         String
  createdAt       DateTime          @default(now())
  updatedAt       DateTime
  ai_models       ai_models[]
  user_ai_configs user_ai_configs[]
}

model finance_accounts {
  id                   String                 @id
  userId               String
  name                 String
  type                 FinanceAccountType     @default(PERSONAL)
  isDefault            Boolean                @default(false)
  createdAt            DateTime               @default(now())
  updatedAt            DateTime
  User                 User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  finance_transactions finance_transactions[]

  @@unique([userId, name])
  @@index([userId])
}

model finance_attachments {
  id                   String               @id
  userId               String
  transactionId        String
  url                  String
  fileName             String?
  mimeType             String?
  sizeBytes            Int?
  createdAt            DateTime             @default(now())
  finance_transactions finance_transactions @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  User                 User                 @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([transactionId])
  @@index([userId])
}

model finance_categories {
  id                   String                 @id
  userId               String
  name                 String
  type                 FinanceTxType
  color                String?
  order                Int                    @default(0)
  createdAt            DateTime               @default(now())
  updatedAt            DateTime
  User                 User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  finance_transactions finance_transactions[]

  @@unique([userId, type, name])
  @@index([userId, type])
}

model finance_currencies {
  code                 String                 @id
  name                 String
  symbol               String
  decimals             Int                    @default(2)
  createdAt            DateTime               @default(now())
  updatedAt            DateTime
  finance_transactions finance_transactions[]
}

model finance_transactions {
  id                  String                @id
  userId              String
  type                FinanceTxType
  status              FinanceTxStatus       @default(ACTIVE)
  occurredAt          DateTime
  amount              Decimal               @db.Decimal(18, 2)
  currencyCode        String
  accountId           String
  categoryId          String?
  title               String?
  description         String?
  counterparty        String?
  reference           String?
  createdAt           DateTime              @default(now())
  updatedAt           DateTime
  deletedAt           DateTime?
  discount            Decimal               @default(0)
  extra               Decimal               @default(0)
  finance_attachments finance_attachments[]
  finance_accounts    finance_accounts      @relation(fields: [accountId], references: [id])
  finance_categories  finance_categories?   @relation(fields: [categoryId], references: [id])
  finance_currencies  finance_currencies    @relation(fields: [currencyCode], references: [code])
  User                User                  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, accountId, occurredAt])
  @@index([userId, categoryId, occurredAt])
  @@index([userId, currencyCode, occurredAt])
  @@index([userId, occurredAt])
  @@index([userId, type, status])
}

model ia_credits {
  id          String   @id
  userId      String   @unique
  total       Int      @default(0)
  used        Int      @default(0)
  renewalDate DateTime
  createdAt   DateTime @default(now())
  updatedAt   DateTime
  User        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model n8n_chat_histories {
  id         Int    @id @default(autoincrement())
  session_id String @db.VarChar(255)
  message    Json
}

model reseller {
  id                             Int      @id @default(autoincrement())
  resellerid                     String?
  userId                         String?
  createdAt                      DateTime @default(now())
  updatedAt                      DateTime
  theme                          ThemeApp @default(Default)
  User_reseller_reselleridToUser User?    @relation("reseller_reselleridToUser", fields: [resellerid], references: [id])
  User_reseller_userIdToUser     User?    @relation("reseller_userIdToUser", fields: [userId], references: [id])
}

model rr {
  id         Int      @id @default(autoincrement())
  workflowId String
  mensaje    String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime
  userId     String
}

model seguimientos {
  id          Int     @id @default(autoincrement())
  idNodo      String?
  serverurl   String?
  instancia   String?
  apikey      String?
  remoteJid   String?
  mensaje     String?
  tipo        String?
  time        String?
  name_file   String?
  consecutivo String?
  media       String?
}

model user_ai_configs {
  id           String       @id
  userId       String
  providerId   String
  apiKey       String
  isActive     Boolean      @default(true)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime
  ai_providers ai_providers @relation(fields: [providerId], references: [id])
  User         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, providerId])
}

enum AppointmentStatus {
  PENDIENTE
  CONFIRMADA
  CANCELADA
}

enum FinanceAccountType {
  COMPANY
  PERSONAL
}

enum FinanceTxStatus {
  ACTIVE
  VOIDED
  DELETED
}

enum FinanceTxType {
  SALE
  EXPENSE
}

enum Plan {
  enterprise
  lite
  unico
  basico
  intermedio
  avanzado
  personalizado
}

enum PromptStatus {
  draft
  published
}

enum RepeatType {
  NONE
  DAILY
  WEEKLY
  MONTHLY
  YEARLY
  WEEKDAYS
  EVERYDAY
}

enum Role {
  user
  admin
  reseller
}

enum ThemeApp {
  Default
  Red
  Rose
  Orange
  Green
  Blue
  Yellow
  Violet
  Cyan
  Black
  White
  Teal
  MidnightBlue
  AquaBlue
  LightBlue
}

enum TipoRegistro {
  REPORTE
  SOLICITUD
  PEDIDO
  RECLAMO
  PAGO
  RESERVA
}

enum TypePromptAi {
  TRAINING
  FAQs
  ACTIONS
  DATA_CAPTURE
  DATA_QUERY
}
